# Expo / React Native — variáveis de ambiente
# Copie este arquivo para .env e preencha com os valores reais
# NUNCA commite o arquivo .env

# Supabase — anon key (pública, usada no app)
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Supabase — service role key (secreta, usada apenas em scripts admin locais)
# Obtenha em: Supabase Dashboard → Project Settings → API
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# URL do projeto Supabase
EXPO_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
